rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidPost(data) {
      return data.title is string && data.title.size() <= 120
          && data.description is string && data.description.size() <= 1000
          && data.type in ['lost', 'found']
          && data.category in ['documents', 'keys', 'phones', 'others']
          && data.wilaya is string && data.wilaya.size() <= 100
          && data.commune is string && data.commune.size() <= 100
          && data.status in ['active', 'resolved']
          && (data.image == null || (data.image is string && data.image.size() <= 5000000))
          && (data.contactNumber == null || (data.contactNumber is string && data.contactNumber.size() <= 30))
          && data.ownerId == request.auth.uid;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(postId) && isValidPost(incoming())
                     && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(postId) && (
        existing().ownerId == request.auth.uid && isValidPost(incoming())
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status'])
          || incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'wilaya', 'commune', 'image', 'status', 'contactNumber', 'securityQuestion', 'securityAnswer'])
        )
      );
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
